# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://pakflood:pakflood@localhost:5432/pakflood

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:3000"]

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── External Data Sources (optional for MVP) ──────────────────────────────────
# ReliefWeb does not require auth for public queries
RELIEFWEB_API_KEY=

# Google Earth Engine service account (Phase 7A+ live rainfall)
GEE_SERVICE_ACCOUNT=
GEE_KEY_FILE=path/to/gee-key.json
GEE_PROJECT=

# Rainfall live mode (Phase 7A+)
# Set ENABLE_LIVE_RAINFALL=true and RAINFALL_PROVIDER=gee|earthdata to attempt live fetches.
# Falls back to stub data (status=stale) if auth/network fails or flag is false.
ENABLE_LIVE_RAINFALL=false
RAINFALL_PROVIDER=stub

# NASA Earthdata credentials (only used when RAINFALL_PROVIDER=earthdata)
NASA_EARTHDATA_USERNAME=
NASA_EARTHDATA_PASSWORD=

# Cloud Storage (Phase 6)
GCS_BUCKET_NAME=pakflood-artifacts

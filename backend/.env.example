# Example .env for PakFlood AI backend
# Copy to backend/.env and customize values for your environment.

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-development

# CORS: comma-separated list of allowed origins
# Include the frontend dev host (Vite/Next) you use, e.g. http://localhost:5174
CORS_ORIGINS=http://localhost:5174,http://localhost:3000

# Supabase (optional)
SUPABASE_URL=
SUPABASE_KEY=

# Admin API key (required for /admin endpoints)
ADMIN_API_KEY=replace-with-secure-key

# Zone grid / scheduler
GRID_STEP_DEGREES=0.5
ZONE_CACHE_TTL_MINUTES=180
OPEN_METEO_REQUEST_DELAY_SEC=0.7
OPEN_METEO_MAX_RETRIES=4
OPEN_METEO_RETRY_BASE_SEC=15.0
ZONE_STARTUP_DELAY_SEC=60

# Pakistan bounding box (defaults used in code)
PAK_NORTH=37.0
PAK_SOUTH=23.5
PAK_EAST=77.0
PAK_WEST=60.5
